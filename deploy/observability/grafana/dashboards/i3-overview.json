            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(i3_pipeline_stage_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Router arm distribution",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "i3-prometheus"
      },
      "gridPos": { "h": 9, "w": 6, "x": 12, "y": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
