{
  "ignorePatterns": [
    { "pattern": "^http://localhost" },
    { "pattern": "^https?://127\\.0\\.0\\.1" },
    { "pattern": "^https?://0\\.0\\.0\\.0" },
    { "pattern": "^#" },
    { "pattern": "^mailto:" },
    { "pattern": "^https?://github\\.com/.+/(issues|pull)/new" }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/",
      "replacement": "https://github.com/abailey81/i3/blob/main/"
    }
  ],
  "httpHeaders": [
    {
      "urls": ["https://github.com/", "https://raw.githubusercontent.com/"],
      "headers": {
        "Accept": "text/html,application/xhtml+xml"
      }
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 301, 302, 307, 308, 403, 429]
}
