{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "python",
  "packages": {
    ".": {
      "package-name": "implicit-interaction-intelligence",
      "component": "i3",
      "release-type": "python",
      "changelog-path": "CHANGELOG.md",
      "include-component-in-tag": false,
      "include-v-in-tag": true,
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false,
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.tool.poetry.version"
        }
      ]
    }
  },
  "plugins": [
    {
      "type": "sentence-case"
    }
  ],
  "changelog-sections": [
    { "type": "feat", "section": "New Features", "hidden": false },
    { "type": "fix", "section": "Bug Fixes", "hidden": false },
    { "type": "perf", "section": "Performance", "hidden": false },
    { "type": "security", "section": "Security", "hidden": false },
    { "type": "refactor", "section": "Refactoring", "hidden": false },
    { "type": "docs", "section": "Documentation", "hidden": false },
    { "type": "build", "section": "Build System", "hidden": false },
    { "type": "deps", "section": "Dependencies", "hidden": false },
    { "type": "ci", "section": "Continuous Integration", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "chore", "section": "Miscellaneous Chores", "hidden": true },
    { "type": "style", "section": "Styles", "hidden": true }
  ],
  "pull-request-title-pattern": "chore(release): ${version}",
  "pull-request-header": "Automated release PR generated by release-please. Merging this PR will cut a new version, publish to PyPI, and produce SLSA Level 3 provenance.",
  "separate-pull-requests": false
}
