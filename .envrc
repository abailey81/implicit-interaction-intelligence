# .envrc — direnv integration
#
# When you cd into this repo, direnv will enter the Nix flake dev shell.
# Install direnv: https://direnv.net/   Install nix-direnv: https://github.com/nix-community/nix-direnv
#
# Then run:   direnv allow
#
# ---------------------------------------------------------------------------
use flake .

# Make the uv cache repo-local so it's always reproducible.
export UV_CACHE_DIR="$PWD/.uv-cache"

# Prefer the interpreter pinned in .python-version.
export UV_PYTHON_PREFERENCE="managed"

# Keep virtualenvs out of $HOME so different checkouts don't collide.
export POETRY_VIRTUALENVS_IN_PROJECT=true
