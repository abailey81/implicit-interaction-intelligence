# ============================================================================
# Implicit Interaction Intelligence — Environment Variables
# Copy this file to `.env` and fill in your values.
# ============================================================================

# ─── Cloud LLM (Anthropic Claude) ─────────────────────────────────────────
# Required for cloud-routed responses and session summaries.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the default model used for cloud routing.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Privacy & Encryption ─────────────────────────────────────────────────
# Fernet symmetric encryption key for user models at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or run:       python scripts/generate_encryption_key.py --update-env
I3_ENCRYPTION_KEY=

# ─── Server Configuration ─────────────────────────────────────────────────
# Bind to loopback by default; set to 0.0.0.0 only if you intentionally
# want to expose the server on all interfaces.
I3_HOST=127.0.0.1
I3_PORT=8000
I3_LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins (required in production).
# Wildcard "*" is ignored unless I3_ALLOW_CORS_WILDCARD=1 is also set.
I3_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ─── Model Paths ──────────────────────────────────────────────────────────
I3_ENCODER_CHECKPOINT=checkpoints/encoder/best.pt
I3_SLM_CHECKPOINT=checkpoints/slm/best.pt

# ─── Database ─────────────────────────────────────────────────────────────
# SQLite database path for diary / adaptation history.
I3_DB_PATH=data/i3.db

# ─── Feature Flags ────────────────────────────────────────────────────────
# Set to "true" to enable on-device inference only (no cloud fallback).
I3_OFFLINE_ONLY=false

# Set to "true" to enable verbose telemetry logging.
I3_TELEMETRY_DEBUG=false

# Disable the OpenAPI schema + /api/docs + /api/redoc in production
# (recommended for public-facing deployments).
# I3_DISABLE_OPENAPI=1

# Set to 1 to permit CORS wildcard origins. Default (unset) forbids them.
# I3_ALLOW_CORS_WILDCARD=0

# ─── Observability — Logging ──────────────────────────────────────────────
# Structured-log format: "json" (production) or "console" (dev-friendly).
I3_LOG_FORMAT=json

# Root log level: DEBUG / INFO / WARNING / ERROR.
I3_LOG_LEVEL=INFO

# ─── Observability — OpenTelemetry ────────────────────────────────────────
# All OTel vars are OPTIONAL; the service boots fine without an OTel collector.
# OTLP endpoint for traces + metrics. Leave unset for no-op tracer.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=i3-server
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=1.0

# ─── Observability — Prometheus ───────────────────────────────────────────
# Set to 0 to disable the /api/metrics scrape endpoint (default: enabled).
I3_METRICS_ENABLED=1

# ─── Observability — Sentry (optional) ────────────────────────────────────
# If SENTRY_DSN is unset, Sentry stays disabled and no network calls are made.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=dev
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Observability — Langfuse LLM tracing (optional) ──────────────────────
# If keys are unset, the LangfuseTracer becomes a no-op decorator.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ─── MLOps — MLflow experiment tracking (optional) ────────────────────────
# Defaults to `file:./mlruns` if unset, so runs work offline out of the box.
# MLFLOW_TRACKING_URI=file:./mlruns
# MLFLOW_EXPERIMENT_NAME=i3-experiments

# ─── Benchmarks / Edge profiling ──────────────────────────────────────────
# Set to 1 to make benchmarks fail when real checkpoints are missing (CI).
# Default: 0 — benchmarks fall back to random-init models.
# I3_BENCH_REQUIRE_CKPT=0

# ─── Runtime tuning ───────────────────────────────────────────────────────
# Uvicorn worker count (1 for WebSocket state; scale behind a reverse proxy).
# I3_WORKERS=1

# Comma-separated IPs trusted to set X-Forwarded-For. Default: 127.0.0.1.
# I3_FORWARDED_IPS=127.0.0.1
