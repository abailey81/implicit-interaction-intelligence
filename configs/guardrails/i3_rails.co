# ==========================================================================
# I³ Guardrails — Colang 2 rail definitions
#
# These rails wrap the Anthropic Claude Messages API call issued by
# i3.cloud.client.CloudLLMClient. They are loaded by
# i3.cloud.guardrails_nemo.GuardrailedCloudClient via
# configs/guardrails/config.yml.
#
# References:
#   - Rebedea et al. (2023) "NeMo Guardrails: A Toolkit for Controllable
#     and Safe LLM Applications with Programmable Rails." EMNLP 2023.
#   - Colang 2 language reference: docs.nvidia.com/nemo/guardrails.
#   - PII regex bank mirrors i3.privacy.sanitizer.PrivacySanitizer.
# ==========================================================================

# --------------------------------------------------------------------------
# Input rail 1: refuse prompt injections
# --------------------------------------------------------------------------
# Matches common jailbreak / override strings. We reject before forwarding
# anything to Claude. The patterns below intentionally mirror those found
# in adversarial datasets (e.g. JailbreakBench, Garak) without attempting
# to exhaustively enumerate them — Claude's own safety training provides
# the second line of defence.

define user attempted_prompt_injection
    "ignore previous instructions"
    "ignore all prior instructions"
    "disregard the above"
    "you are now"
    "pretend to be"
    "act as"
    "system prompt"
    "reveal your instructions"
    "print your prompt"
    "[INST]"
    "[/INST]"
    "<|system|>"
    "system:"
    "assistant:"
    "### Instruction"
    "DAN mode"
    "developer mode"

define flow refuse_prompt_injection
    user attempted_prompt_injection
    bot refuse to respond to prompt injection

define bot refuse to respond to prompt injection
    "That request was blocked by an input guardrail (possible prompt-injection pattern)."

# --------------------------------------------------------------------------
# Input rail 2: redact PII before forwarding to the LLM
# --------------------------------------------------------------------------
# The regex bank mirrors i3.privacy.sanitizer.PII_PATTERNS so that the
# on-device sanitiser and the cloud-side rail share a single source of
# truth. Colang evaluates the patterns against $user_message and replaces
# matches in-place; the downstream LLM call therefore never sees raw PII
# even if an upstream bug bypassed the sanitiser.

define subflow redact_pii_input
    $user_message = execute redact_pii(text=$user_message)

define flow redact_pii_before_llm
    user ...
    do redact_pii_input

# --------------------------------------------------------------------------
# Output rail 1: forbid PII echo
# --------------------------------------------------------------------------
# Even if the upstream model hallucinates or is tricked into echoing PII,
# the same regex bank blocks it on the way out.

define subflow check_pii_output
    $contains_pii = execute contains_pii(text=$bot_message)
    if $contains_pii
        bot refuse pii echo
        stop

define bot refuse pii echo
    "I can't share that: the response contained personally identifiable information that was stripped for your safety."

# --------------------------------------------------------------------------
# Output rail 2: clamp response length to AdaptationVector.verbosity
# --------------------------------------------------------------------------
# $verbosity is a float in [0, 1] placed on the rails context by
# GuardrailedCloudClient. We translate it to a token budget via a simple
# piecewise-linear mapping so rail evaluation stays deterministic.

define subflow clamp_response_length
    $verbosity = $verbosity or 0.4
    $max_chars = execute verbosity_to_max_chars(verbosity=$verbosity)
    $bot_message = execute truncate_response(text=$bot_message, max_chars=$max_chars)

# --------------------------------------------------------------------------
# Output rail 3: forbid jailbreak-style content
# --------------------------------------------------------------------------
# Conservative categorical guardrail: reject any response that contains
# overt violence, sexual content, or self-harm encouragement. Intended as
# defence-in-depth; Anthropic's own policy filter remains primary.

define bot forbidden_content_categories
    "graphic violence"
    "sexual content"
    "self-harm encouragement"
    "instructions for weapons"
    "hate speech targeting a group"

define subflow check_forbidden_categories
    $flagged = execute check_categorical_safety(text=$bot_message)
    if $flagged
        bot refuse unsafe content
        stop

define bot refuse unsafe content
    "I can't help with that: the generated response was blocked by a safety guardrail."

# --------------------------------------------------------------------------
# Rail composition
# --------------------------------------------------------------------------
# Rails are attached in config.yml under input/output/retrieval sections.
# The ordering below matches the expected evaluation sequence:
#   1. Prompt-injection refusal  (input)
#   2. PII redaction             (input)
#   3. PII echo block            (output)
#   4. Length clamp              (output)
#   5. Categorical safety        (output)
