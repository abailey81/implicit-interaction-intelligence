{
  "__meta__": {
    "name": "I3 on-device valence lexicon",
    "version": "1.0.0",
    "license": "MIT (I3 project)",
    "derivation": "Curated subset inspired by the NRC Emotion Lexicon (Mohammad & Turney, 2013) and VADER (Hutto & Gilbert, 2014) valence entries. This file does NOT redistribute either source word-list verbatim; no file from those projects is copied. Words and valences were hand-selected and hand-scored for on-device use.",
    "scope": "Intended as a lightweight on-device sentiment signal, not a substitute for a trained sentiment classifier. Values are floats in [-1, 1]: +1 strongly positive, -1 strongly negative.",
    "notes": "Negation handling (not / n't / no / never flipping the next 3 tokens) is performed by the consuming module, not encoded in this file.",
    "citations": [
      "Mohammad, S. M. & Turney, P. D. (2013). Crowdsourcing a Word-Emotion Association Lexicon. Computational Intelligence 29(3).",
      "Hutto, C. J. & Gilbert, E. (2014). VADER: A Parsimonious Rule-based Model for Sentiment Analysis of Social Media Text. ICWSM."
    ]
