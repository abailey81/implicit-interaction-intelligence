{
  "__meta__": {
    "name": "I3 on-device valence lexicon",
    "version": "1.1.0",
    "license": "MIT (I3 project)",
    "derivation": "Curated lexicon inspired by the NRC Emotion Lexicon (Mohammad & Turney, 2013), VADER (Hutto & Gilbert, 2014), and AFINN (Nielsen, 2011). This file does NOT redistribute any source word-list verbatim — words and valence scores were hand-selected and hand-scored for an on-device conversational-AI setting. The lexicon includes general affective vocabulary plus HCI / developer-experience terms that are common in conversational logs but rare in general-purpose lexica.",
    "scope": "A lightweight on-device sentiment signal, not a substitute for a trained classifier. Valence values are floats in [-1, +1]: +1 strongly positive, -1 strongly negative, ~0 mildly affective.",
    "negation_handling": "Performed by the consuming module (i3.interaction.sentiment.ValenceLexicon): tokens 'not' / 'no' / 'never' / \"n't\" flip the valence sign of up to three subsequent tokens, with a decay factor.",
    "coverage": {
      "positive_entries": 254,
      "negative_entries": 256,
      "total": 510
    },
    "categories": [
      "affect (happiness, sadness, anger, fear, disgust, surprise, trust, anticipation)",
      "evaluation (good / bad, right / wrong, useful / useless)",
      "achievement + failure",
      "social (warm / rude, kind / cruel)",
      "aesthetic (beautiful / ugly)",
      "physical state (tired, fresh, sick, healthy)",
      "task state (broken, working, stuck, flowing)",
      "informal and interjections (yay, ugh, lol, meh)"
    ],
    "citations": [
      "Mohammad, S. M. & Turney, P. D. (2013). Crowdsourcing a Word-Emotion Association Lexicon. Computational Intelligence 29(3), 436-465.",
      "Hutto, C. J. & Gilbert, E. (2014). VADER: A Parsimonious Rule-based Model for Sentiment Analysis of Social Media Text. Proc. ICWSM.",
      "Nielsen, F. Å. (2011). A new ANEW: Evaluation of a word list for sentiment analysis in microblogs. Proc. ESWC Workshop on 'Making Sense of Microposts'."
    ]
  },
