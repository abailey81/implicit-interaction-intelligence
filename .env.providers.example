# ---------------------------------------------------------------------------
# I3 universal provider layer -- example env file.
#
# Copy to ``.env.providers`` (or merge into your existing ``.env``) and
# fill in credentials for the provider(s) you want to use.  Every
# provider is soft-imported: missing SDKs only fail when you actually
# call that provider's .complete().
# ---------------------------------------------------------------------------

# --- Active provider (maps to i3.cloud.provider_registry keys) ---
I3_LLM_PROVIDER=anthropic

# --- Test gate for live-API integration tests ---
# Set to "1" to exercise real endpoints in tests/test_*_live.py.
# Leave unset in CI unless you've provisioned the matching credentials.
I3_TEST_LIVE_PROVIDERS=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google Gemini ---
GOOGLE_API_KEY=

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# Optional; defaults to 2024-10-21 inside the adapter.
# AZURE_OPENAI_API_VERSION=2024-10-21

# --- AWS Bedrock (default AWS credential chain also works) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Mistral AI ---
MISTRAL_API_KEY=

# --- Cohere ---
COHERE_API_KEY=

# --- Ollama (local; no API key needed) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- OpenRouter ---
OPENROUTER_API_KEY=

# --- Huawei Cloud PanGu (strategic first-party provider) ---
# Requires a Huawei Cloud account with PanGu Large Models enabled.
HUAWEI_CLOUD_PANGU_APIKEY=
HUAWEI_CLOUD_PANGU_REGION=cn-southwest-2
